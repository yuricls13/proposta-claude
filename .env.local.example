# ============================================
# Proposta App — Variáveis de ambiente
# ============================================
# Copie para .env.local (não comitado).
# Em produção (Vercel), defina essas vars no dashboard ou via `vercel env add`.

# Postgres URL — connection pool (PgBouncer) para Prisma Client
# Use Neon, Supabase, Vercel Postgres ou qualquer Postgres acessível.
# Local: pode rodar com Postgres em Docker ou puxar via `vercel env pull`
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Postgres URL direta — sem pool, usada por `prisma migrate` e `prisma db push`
# Nome alinhado ao que Neon/Vercel Marketplace provisiona automaticamente.
DATABASE_URL_UNPOOLED="postgresql://user:password@host:5432/dbname?sslmode=require"

# Segredo de sessão — qualquer string aleatória forte (32+ chars)
SESSION_SECRET="troque-em-producao-este-segredo-aleatorio-de-32-chars-ou-mais"

# Opcional: Resend para e-mails reais (sem isso, e-mails são mockados no console)
# RESEND_API_KEY=""
